rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Menu and Config 
    match /menu/{menuId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /config/{configId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orders Collection
    match /orders/{orderId} {
      // Must be able to create without auth
      allow create: if true;
      // Admin dashboard reads/updates them
      allow read, update, delete: if true; // Temporarily allow all to debug!
    }

    // Default catch-all
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}